PORT=4000
CONTACT_RECIPIENT=you@example.com

# Optional SMTP settings for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# API_KEY or JWT_SECRET for admin endpoints
API_KEY=

# Send confirmation email back to sender when a message is received (true/false)
SEND_CONFIRMATION=false
# Optional: confirmation email subject and template ({{name}} placeholder)
CONFIRM_SUBJECT=Thanks for contacting me
CONFIRM_TEMPLATE=Hi {{name}},\n\nThanks for reaching out — I received your message and will get back to you soon.

# Sentry DSN for backend error monitoring
SENTRY_DSN=
